From 78f1dae72a102d234ccfd06eca29d36eab40ab96 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 20 Mar 2026 20:00:49 +0000
Subject: [PATCH] Fix 3 crash-causing bugs from audit commit validators
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

1. repairMalformedJson: whitespace after a trailing comma was flushing
   the pending-comma buffer prematurely, so ",  }" was never repaired
   to "}". This caused most LLM tool calls with trailing commas to
   fail JSON parsing and error out.

2. InputValidator.isValidJson: naive bracket-matching check rejected
   valid API responses (e.g. with BOM, trailing data). Replaced with
   actual kotlinx.serialization parse attempt. Also removed the
   redundant pre-check in executeWithRetry since parseResponse already
   handles invalid JSON gracefully.

3. InputValidator.isValidApiKey: regex was too strict (rejected dots,
   colons) and min length too high (20→10). Keys from some providers
   were silently rejected, breaking all API calls.

https://claude.ai/code/session_01B9CtX7SJ6DDp6MkfBGUvCb
---
 .../com/vesper/flipper/ai/OpenRouterClient.kt | 29 +++++++++----------
 .../vesper/flipper/security/SecurityUtils.kt  | 18 ++++++------
 2 files changed, 22 insertions(+), 25 deletions(-)

diff --git a/app/src/main/java/com/vesper/flipper/ai/OpenRouterClient.kt b/app/src/main/java/com/vesper/flipper/ai/OpenRouterClient.kt
index 580e6bc..68c036a 100644
--- a/app/src/main/java/com/vesper/flipper/ai/OpenRouterClient.kt
+++ b/app/src/main/java/com/vesper/flipper/ai/OpenRouterClient.kt
@@ -501,11 +501,6 @@ class OpenRouterClient @Inject constructor(
                         return ChatCompletionResult.Error("Empty response from API")
                     }
 
-                    // Validate response is valid JSON
-                    if (!InputValidator.isValidJson(responseBody)) {
-                        return ChatCompletionResult.Error("Invalid JSON response from API")
-                    }
-
                     return parseResponse(responseBody)
                 }
 
@@ -1025,20 +1020,22 @@ class OpenRouterClient @Inject constructor(
                         else if (ch == ']' && stack.lastOrNull() == '[') stack.removeLast()
                     }
                     else -> {
-                        // Flush buffered comma — it was not trailing
-                        pendingComma?.let { sb.append(it); pendingComma = null }
-                        sb.append(ch)
-                        when (ch) {
-                            '"' -> inString = true
-                            '{' -> stack.add('{')
-                            '[' -> stack.add('[')
+                        if (ch.isWhitespace() && pendingComma != null) {
+                            // Accumulate whitespace into the pending comma buffer
+                            // so ",  }" correctly drops the comma + whitespace.
+                            pendingComma!!.append(ch)
+                        } else {
+                            // Non-whitespace after comma — flush buffer, it's not trailing
+                            pendingComma?.let { sb.append(it); pendingComma = null }
+                            sb.append(ch)
+                            when (ch) {
+                                '"' -> inString = true
+                                '{' -> stack.add('{')
+                                '[' -> stack.add('[')
+                            }
                         }
                     }
                 }
-                // Accumulate whitespace into the pending comma buffer
-                if (ch.isWhitespace() && pendingComma != null) {
-                    pendingComma!!.append(ch)
-                }
             }
         }
 
diff --git a/app/src/main/java/com/vesper/flipper/security/SecurityUtils.kt b/app/src/main/java/com/vesper/flipper/security/SecurityUtils.kt
index babd424..c6aff97 100644
--- a/app/src/main/java/com/vesper/flipper/security/SecurityUtils.kt
+++ b/app/src/main/java/com/vesper/flipper/security/SecurityUtils.kt
@@ -260,12 +260,13 @@ object InputValidator {
     }
 
     /**
-     * Validate an API key format
+     * Validate an API key format.
+     * Accepts alphanumeric characters plus common delimiters used by various
+     * providers (e.g. OpenRouter "sk-or-v1-…", OpenAI "sk-proj-…").
      */
     fun isValidApiKey(key: String): Boolean {
-        // OpenRouter keys are typically "sk-or-..." format
-        return key.length in 20..200 &&
-               key.matches(Regex("^[a-zA-Z0-9_-]+\$"))
+        return key.length in 10..500 &&
+               key.matches(Regex("^[a-zA-Z0-9_.\\-:]+\$"))
     }
 
     /**
@@ -280,14 +281,13 @@ object InputValidator {
     }
 
     /**
-     * Validate JSON structure (basic check)
+     * Validate JSON structure by attempting a parse.
      */
     fun isValidJson(json: String): Boolean {
         return try {
-            val trimmed = json.trim()
-            (trimmed.startsWith("{") && trimmed.endsWith("}")) ||
-            (trimmed.startsWith("[") && trimmed.endsWith("]"))
-        } catch (e: Exception) {
+            kotlinx.serialization.json.Json.parseToJsonElement(json)
+            true
+        } catch (_: Exception) {
             false
         }
     }
