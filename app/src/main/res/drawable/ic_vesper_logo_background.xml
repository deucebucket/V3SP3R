<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep black background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF060610" />
        </shape>
    </item>

    <!-- Subtle orange radial glow from center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="54dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#20FF8800"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
